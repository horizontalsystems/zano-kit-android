From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: chyngyz <chyngyz.omurov@gmail.com>
Date: Fri, 25 Apr 2026 00:00:00 +0600
Subject: [PATCH] Add generate_address and generate_address_from_derivation
 methods to PlainWallet

---
 src/currency_core/account.h     |  3 +--
 src/wallet/plain_wallet_api.cpp | 30 ++++++++++++++++++++++++++++++
 src/wallet/plain_wallet_api.h   |  4 +++-
 3 files changed, 34 insertions(+), 3 deletions(-)

diff --git a/src/currency_core/account.h b/src/currency_core/account.h
index 855f7ed6..e2061f85 100644
--- a/src/currency_core/account.h
+++ b/src/currency_core/account.h
@@ -87,7 +87,7 @@ namespace currency
     static bool is_seed_password_protected(const std::string& seed_phrase, bool& is_password_protected);
     static bool is_seed_tracking(const std::string& seed_phrase);
     static void crypt_with_pass(const void* scr_data, std::size_t src_length, void* dst_data, const std::string& password);
-
+    void set_null();

     BEGIN_KV_SERIALIZE_MAP()
       KV_SERIALIZE(m_keys)
@@ -96,7 +96,6 @@ namespace currency
     END_KV_SERIALIZE_MAP()

   private:
-    void set_null();
     bool restore_keys(const std::vector<unsigned char>& keys_seed_binary);

     account_keys m_keys;
diff --git a/src/wallet/plain_wallet_api.cpp b/src/wallet/plain_wallet_api.cpp
index b01f60e6..bc66036a 100644
--- a/src/wallet/plain_wallet_api.cpp
+++ b/src/wallet/plain_wallet_api.cpp
@@ -952,4 +952,34 @@ namespace plain_wallet
   {
     return currency::get_timestamp_from_word(word, password_used);
   }
+
+  std::string generate_address_from_derivation(const std::string& secret_derivation_hex, bool is_auditable)
+  {
+    std::string binary;
+    if (!epee::string_tools::parse_hexstr_to_binbuff(secret_derivation_hex, binary))
+      return "";
+
+    currency::account_base acc;
+    if (!acc.restore_from_secret_derivation(binary, is_auditable, 0))
+    {
+      acc.set_null();
+      return "";
+    }
+    std::string result = acc.get_public_address_str();
+    acc.set_null();
+    return result;
+  }
+
+  std::string generate_address(const std::string& seed, const std::string& seed_password)
+  {
+    currency::account_base acc;
+    if (!acc.restore_from_seed_phrase(seed, seed_password))
+    {
+      acc.set_null();
+      return "";
+    }
+    std::string result = acc.get_public_address_str();
+    acc.set_null();
+    return result;
+  }
 }
\ No newline at end of file
diff --git a/src/wallet/plain_wallet_api.h b/src/wallet/plain_wallet_api.h
index 1f910ab2..81278794 100644
--- a/src/wallet/plain_wallet_api.h
+++ b/src/wallet/plain_wallet_api.h
@@ -48,7 +48,9 @@ namespace plain_wallet
   std::string reset_wallet_password(hwallet h, const std::string& password);
   uint64_t get_current_tx_fee(uint64_t priority); // 0 (default), 1 (unimportant), 2 (normal), 3 (elevated), 4 (priority)
   uint64_t get_timestamp_from_word(const std::string& word, bool& password_used);
-
+  std::string generate_address_from_derivation(const std::string& secret_derivation_hex, bool is_auditable);
+  std::string generate_address(const std::string& seed, const std::string& seed_password);
+
   //callback-mode for async calls
   typedef void (*callback_type)(uint64_t job_id, const std::string& job_response);
   void set_callback(callback_type callback);
